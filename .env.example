# Copy to .env.local (local) or set in Vercel → Project → Settings → Environment Variables.
# Everything is OPTIONAL — the portal runs fully without any of these (JARVIS uses its data-engine,
# automations show a "Connect n8n" state).

# ── JARVIS ChatGPT mode (server-side, never exposed to the browser) ──
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
# Cheaper model used by batch jobs (supply intelligence runs every 12h):
OPENAI_BATCH_MODEL=gpt-4o-mini

# ── n8n public API (server-side) — lets the portal create/run workflows via API ──
N8N_API_BASE_URL=
N8N_API_KEY=

# ── ERP scheduled sync (internal workflow source) ──
ERP_BASE_URL=
ERP_API_KEY=

# ── Supply-intelligence external search (optional; RSS mode needs none) ──
TAVILY_API_KEY=

# ── Supabase (storage for ERP sync + supply-intelligence output) ──
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_SECRET_KEY=

# ── n8n automation webhooks (NEXT_PUBLIC_* are inlined into the browser bundle) ──
# Paste the Production webhook URL from each n8n workflow to make its "Run" button live.
NEXT_PUBLIC_N8N_ERP_SYNC=
NEXT_PUBLIC_N8N_SUPPLY_INTEL=
NEXT_PUBLIC_N8N_EMAIL_INTAKE=
NEXT_PUBLIC_N8N_WHATSAPP_INTAKE=
NEXT_PUBLIC_N8N_ORDER_APPROVAL=
NEXT_PUBLIC_N8N_WAREHOUSE_DISPATCH=
NEXT_PUBLIC_N8N_DRIVER_ROUTE=
NEXT_PUBLIC_N8N_DELIVERY_NOTE=
NEXT_PUBLIC_N8N_PAYMENT_FOLLOWUP=
NEXT_PUBLIC_N8N_EXCEL_EXPORT=
NEXT_PUBLIC_N8N_SUPPLIER_PLANNING=
NEXT_PUBLIC_N8N_LEARNING=
